generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  price      Int
  category   String
  height     Int
  length     Int
  width      Int
  weight     Int
  weightUnit String   @default("kg")
  image1     String
  image2     String?
  createdAt  DateTime @default(now())
}

model Banner {
  id        Int      @id @default(autoincrement())
  image     String
  updatedAt DateTime @updatedAt
}